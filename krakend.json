{
  "$schema": "https://www.krakend.io/schema/v3.json",
  "version": 3,
  "timeout": "3000ms",
  "port": 8080,
  "cache_ttl": "0s",
  "extra_config": {
    "router": {
      "auto_options": true
    },
    "telemetry/usage": {
      "disabled": true
    },
    "security/cors": {
      "allow_origins": [
        "*"
      ],
      "allow_methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH"
      ],
      "allow_headers": [
        "Origin",
        "Authorization",
        "Content-Type",
        "Accept"
      ],
      "expose_headers": [
        "Content-Length"
      ],
      "max_age": "12h"
    }
  },
  "endpoints": [
    {
      "endpoint": "/chat_service/health_check/",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/real_time_chat/health_check/",
          "host": [
            "http://rt_chat-chat-api:8001"
          ]
        }
      ]
    },
    {
      "endpoint": "/users_service/health_check/",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/health_check",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/media_service/health_check/",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/media_service/health_check/",
          "host": [
            "http://rt_chat-media-api:8003"
          ]
        }
      ]
    },
    {
      "endpoint": "/chat/",
      "method": "GET",
      "input_headers": ["Authorization"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/real_time_chat/",
          "host": [
            "http://rt_chat-chat-api:8001"
          ]
        }
      ]
    },
    {
      "endpoint": "/chat/messages",
      "method": "POST",
      "input_headers": ["Authorization", "Content-Type"],
      "backend": [
        {
          "url_pattern": "/api/v1/real_time_chat/messages",
          "host": [
            "http://rt_chat-chat-api:8001"
          ]
        }
      ]
    },
    {
      "endpoint": "/chat/messages/{user_id}",
      "method": "GET",
      "input_headers": ["Authorization"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/real_time_chat/messages/{user_id}",
          "host": [
            "http://rt_chat-chat-api:8001"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/register/",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/register/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/login/",
      "method": "POST",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/login/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/refresh_tokens/",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Authorization"],
      "backend": [
        {
          "url_pattern": "/users/tokens/refresh/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/logout/",
      "method": "POST",
      "output_encoding": "no-op",
      "input_headers": ["Authorization"],
      "backend": [
        {
          "url_pattern": "/users/logout/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/self_info/",
      "method": "GET",
      "input_headers": ["Authorization"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/me/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/get_all_users/",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/get_all_users/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/user/search/",
      "method": "GET",
      "input_query_strings": ["search"],
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/users/search/",
          "host": [
            "http://rt_chat-users-api:8002"
          ]
        }
      ]
    },
    {
      "endpoint": "/media_service/upload",
      "method": "POST",
      "input_query_strings": ["upload_context", "entity_id"],
      "input_headers": ["Content-Type"],
      "timeout": "10s",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/media_service/upload",
          "host": [
            "http://rt_chat-media-api:8003"
          ]
        }
      ]
    },
    {
      "endpoint": "/media_service/files/{file_uuid}/",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/media_service/files/{file_uuid}/",
          "host": [
            "http://rt_chat-media-api:8003"
          ]
        }
      ]
    },
    {
      "endpoint": "/media_service/files/{file_uuid}/view/",
      "method": "GET",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/media_service/files/{file_uuid}/view/",
          "host": [
            "http://rt_chat-media-api:8003"
          ]
        }
      ]
    },
    {
      "endpoint": "/media_service/files/delete/{file_uuid}/",
      "method": "DELETE",
      "output_encoding": "no-op",
      "backend": [
        {
          "url_pattern": "/api/v1/media_service/files/delete/{file_uuid}/",
          "host": [
            "http://rt_chat-media-api:8003"
          ]
        }
      ]
    }
  ]
}
